{
  "env": {
    "browser": true,
    "es2023": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none", "varsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-var": "off",
    "prefer-const": "warn",
    "no-console": "off",
    "eqeqeq": ["warn", "smart"],
    "curly": ["warn", "multi-line"],
    "no-throw-literal": "warn",
    "prefer-promise-reject-errors": "warn"
  }
}